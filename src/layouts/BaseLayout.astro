---
import '../styles/global.css'
import baseLayoutScript from '../scripts/base-layout.js?url'

const { title = 'Glory & Game', description = 'Discover Christian athletes and their stories.', pathname = '/' } = Astro.props

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/players/', label: 'Players' },
  { href: '/media/', label: 'Media' },
  { href: '/search/', label: 'Search' },
  { href: '/admin/', label: 'Admin' },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;700;800&family=Manrope:wght@400;500;600;700;800&family=Poppins:wght@700;800;900&display=swap"
    />
  </head>
  <body>
    <canvas class="site-noise" data-site-noise aria-hidden="true"></canvas>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href="/">
            <span class="brand__name">Glory &amp; Game</span>
          </a>
          <button
            class="nav-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="site-nav"
            aria-label="Open menu"
            data-nav-toggle
          >
            <span></span>
            <span></span>
            <span></span>
          </button>
          <nav class="nav" id="site-nav" aria-label="Primary" data-nav>
            {navItems.map((item) => (
              <a
                href={item.href}
                aria-current={pathname === item.href ? 'page' : undefined}
                data-admin-nav-link={item.href === '/admin/' ? 'true' : undefined}
                hidden={item.href === '/admin/'}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </header>

      <main class="page-shell">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner">
          <span>© 2026 Glory &amp; Game • Powered by Brisk</span>
        </div>
      </footer>
    </div>
    <script type="module" src={baseLayoutScript}></script>
  </body>
</html>
