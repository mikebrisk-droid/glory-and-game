---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PlayerCardModal from '../../components/PlayerCardModal.astro'
import { getAthletes } from '../../lib/athlete-repository'
import { findAthleteBySlug } from '../../lib/athletes'
import { formatBioHtml } from '../../lib/rich-text'
import { publicCacheHeader } from '../../lib/http-cache'
import { getAthleteVideoLinks } from '../../lib/video-links'

Astro.response.headers.set('Cache-Control', publicCacheHeader({ sMaxAge: 300, staleWhileRevalidate: 3600 }))
const { slug } = Astro.params
const athletes = await getAthletes()
const athlete = findAthleteBySlug(slug, athletes)
const verseUrl = athlete?.verse
  ? `https://www.bible.com/search/bible?q=${encodeURIComponent(athlete.verse)}`
  : ''

const athleteList = athletes
const currentIndex = athlete ? athleteList.findIndex((a) => a.slug === athlete.slug) : -1
const prevAthlete = athleteList.length > 1 && currentIndex > -1
  ? athleteList[(currentIndex - 1 + athleteList.length) % athleteList.length]
  : null
const nextAthlete = athleteList.length > 1 && currentIndex > -1
  ? athleteList[(currentIndex + 1) % athleteList.length]
  : null
const videoLinks = athlete ? getAthleteVideoLinks(athlete) : []
---

<BaseLayout
  title={`${athlete?.name || 'Athlete Profile'} | Glory & Game`}
  description={athlete?.bio || 'Athlete profile on Glory & Game.'}
  pathname="/players/"
>
  <div data-athlete-detail>
    {athlete ? (
      <>
        <article class="panel detail">
          <div class="detail__media">
            <img src={athlete.image} alt={athlete.name} loading="lazy" decoding="async" />
            <button class="button-secondary detail__card-cta" type="button" data-open-player-card>
              <span class="detail__card-cta-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                </svg>
              </span>
              3D Player Card
            </button>
          </div>
          <div class="detail__copy">
            <div class="detail__topbar">
              <div>
                <p class="eyebrow">Athlete Profile</p>
              </div>
              <div class="detail__topbar-actions">
                <button
                  class="favorite-btn"
                  type="button"
                  aria-label="Save to My Cards"
                  data-favorite-slug={athlete.slug}
                  data-favorite-active="false"
                >
                  <svg class="favorite-btn__empty" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                  </svg>
                  <svg class="favorite-btn__filled" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
                  </svg>
                </button>
              </div>
            </div>
            <h1>{athlete.name}</h1>
            <p class="meta">{athlete.sport} • {athlete.team}</p>
            <div class="detail__bio" set:html={formatBioHtml(athlete.bio)} />
            <div class="verse-row">
              <blockquote>{athlete.verse}</blockquote>
              {verseUrl && (
                <p class="verse-link">
                  <a href={verseUrl} target="_blank" rel="noreferrer">
                    Read on Bible.com
                  </a>
                </p>
              )}
            </div>
            {(athlete.instagram || athlete.x) && (
              <div class="profile-socials">
                <p class="profile-socials__label">Follow</p>
                <div class="profile-socials__links">
                  {athlete.instagram && (
                    <a
                      class="social-button social-button--instagram"
                      href={athlete.instagram}
                      target="_blank"
                      rel="noreferrer"
                    >
                      <span class="social-button__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" role="img" focusable="false">
                          <path
                            d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 1.8A3.7 3.7 0 0 0 3.8 7.5v9a3.7 3.7 0 0 0 3.7 3.7h9a3.7 3.7 0 0 0 3.7-3.7v-9a3.7 3.7 0 0 0-3.7-3.7h-9Zm9.55 1.35a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8A3.2 3.2 0 1 0 12 15.2 3.2 3.2 0 0 0 12 8.8Z"
                            fill="currentColor"
                          />
                        </svg>
                      </span>
                      Instagram
                    </a>
                  )}
                  {athlete.x && (
                    <a class="social-button social-button--x" href={athlete.x} target="_blank" rel="noreferrer">
                      <span class="social-button__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" role="img" focusable="false">
                          <path
                            d="M18.9 2H22l-6.78 7.75L23 22h-6.1l-4.77-6.92L6.08 22H3l7.27-8.32L1 2h6.25l4.31 6.28L18.9 2Zm-1.07 18.13h1.69L6.33 3.77H4.51l13.32 16.36Z"
                            fill="currentColor"
                          />
                        </svg>
                      </span>
                      X
                    </a>
                  )}
                </div>
              </div>
            )}
            {videoLinks.length > 0 && (
              <div class="profile-socials profile-videos">
                <p class="profile-socials__label">Watch</p>
                <div class="profile-socials__links">
                  {videoLinks.map((video) => (
                    <button
                      class:list={[
                        'video-thumb',
                        `video-thumb--${video.id}`,
                      ]}
                      type="button"
                      data-video-trigger
                      data-video-title={`${athlete.name} on ${video.label}`}
                      data-video-embed={video.embedUrl}
                    >
                      <span class="video-thumb__media" aria-hidden="true">
                        {video.thumbnailUrl ? (
                          <img
                            class="video-thumb__image"
                            src={video.thumbnailUrl}
                            alt=""
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <img
                            class="video-thumb__image"
                            src={athlete.image}
                            alt=""
                            loading="lazy"
                            decoding="async"
                          />
                        )}
                        <span class="video-thumb__scrim"></span>
                        <span class="video-thumb__play">
                          <svg viewBox="0 0 24 24" role="img" focusable="false">
                            <path d="M8 6.82v10.36c0 .79.87 1.27 1.54.84l8.14-5.18a1 1 0 0 0 0-1.68L9.54 5.98A1 1 0 0 0 8 6.82Z" fill="currentColor"/>
                          </svg>
                        </span>
                      </span>
                      <span class="video-thumb__body">
                        <span class:list={['video-thumb__badge', `video-thumb__badge--${video.id}`]}>
                          {video.label}
                        </span>
                        <span class="video-thumb__title">Watch {athlete.name}</span>
                      </span>
                    </button>
                  ))}
                </div>
              </div>
            )}
          </div>
        </article>

        {videoLinks.length > 0 && (
          <dialog class="video-modal" data-video-modal>
            <div class="video-modal__shell">
              <button class="video-modal__backdrop" type="button" aria-label="Close video" data-video-close></button>
              <section class="video-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="video-modal-title">
                <div class="video-modal__header">
                  <h2 id="video-modal-title" data-video-modal-title>Watch Video</h2>
                  <button class="button-secondary video-modal__close" type="button" data-video-close>Close</button>
                </div>
                <div class="video-modal__frame-wrap">
                  <iframe
                    data-video-frame
                    src=""
                    title="Athlete video"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    loading="lazy"
                    referrerpolicy="strict-origin-when-cross-origin"
                  ></iframe>
                </div>
              </section>
            </div>
          </dialog>
        )}
        <PlayerCardModal athlete={athlete} verseUrl={verseUrl} prevAthlete={prevAthlete} nextAthlete={nextAthlete} />
      </>
    ) : (
      <article class="panel detail">
        <div class="detail__media">
          <img src="/assets/athletes/default-athlete.jpg" alt="Athlete not found" />
        </div>
        <div class="detail__copy">
          <p class="eyebrow">Athlete Profile</p>
          <h1>Athlete Not Found</h1>
          <p class="meta">Profile • Glory &amp; Game</p>
          <p>We could not find this athlete yet. Browse the directory or submit a new profile.</p>
          <blockquote>Colossians 3:23-24</blockquote>
          <div class="hero__actions">
            <a class="button" href="/submit-profile/">Submit an Athlete</a>
            <a class="button-secondary" href="/players/">Back to Players</a>
          </div>
        </div>
      </article>
    )}
  </div>
</BaseLayout>

<script>
  const btn = document.querySelector('[data-favorite-slug]')
  if (btn instanceof HTMLElement) {
    const slug = btn.dataset.favoriteSlug

    // Load current state
    fetch('/api/favorites')
      .then((r) => r.ok ? r.json() : null)
      .then((data) => {
        if (!data) return
        const active = data.favorites.includes(slug)
        setActive(active)
      })
      .catch(() => {})

    btn.addEventListener('click', async () => {
      const currentlyActive = btn.dataset.favoriteActive === 'true'
      setActive(!currentlyActive) // optimistic
      try {
        const res = await fetch('/api/favorites', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug }),
        })
        if (res.status === 401) {
          setActive(currentlyActive) // revert
          showSignInPrompt()
          return
        }
        if (!res.ok) {
          setActive(currentlyActive)
          return
        }
        const data = await res.json()
        if (data.added) {
          animateHeartToNav(btn)
        }
      } catch {
        setActive(currentlyActive)
      }
    })

    function showSignInPrompt() {
      if (document.querySelector('.favorite-signin-tip')) return
      const tip = document.createElement('div')
      tip.className = 'favorite-signin-tip'
      tip.innerHTML = `
        <span>Sign in to save cards</span>
        <a href="/sign-in">Sign in</a>
      `
      btn.parentElement?.appendChild(tip)
      // animate in
      requestAnimationFrame(() => tip.classList.add('favorite-signin-tip--visible'))
      // auto-dismiss
      setTimeout(() => {
        tip.classList.remove('favorite-signin-tip--visible')
        tip.addEventListener('transitionend', () => tip.remove(), { once: true })
      }, 3500)
    }

    function setActive(active) {
      btn.dataset.favoriteActive = String(active)
      btn.setAttribute('aria-label', active ? 'Remove from My Cards' : 'Save to My Cards')
    }

    function animateHeartToNav(sourceEl) {
      const navLink = document.querySelector('a[href="/collection/"]')
      if (!navLink) return

      const srcRect = sourceEl.getBoundingClientRect()
      const dstRect = navLink.getBoundingClientRect()

      const startX = srcRect.left + srcRect.width / 2
      const startY = srcRect.top + srcRect.height / 2
      const endX = dstRect.left + dstRect.width / 2
      const endY = dstRect.top + dstRect.height / 2

      const heart = document.createElementNS('http://www.w3.org/2000/svg', 'svg')
      heart.setAttribute('viewBox', '0 0 24 24')
      heart.setAttribute('fill', '#e8444a')
      heart.style.cssText = `
        position: fixed;
        width: 28px;
        height: 28px;
        pointer-events: none;
        z-index: 9999;
        left: ${startX - 14}px;
        top: ${startY - 14}px;
      `
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path')
      path.setAttribute('d', 'M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z')
      heart.appendChild(path)
      document.body.appendChild(heart)

      const dx = endX - startX
      const dy = endY - startY

      const anim = heart.animate(
        [
          { transform: 'translate(0, 0) scale(1)', opacity: 1 },
          { transform: `translate(${dx * 0.35}px, ${dy * 0.35 - 24}px) scale(1.3)`, opacity: 1, offset: 0.35 },
          { transform: `translate(${dx}px, ${dy}px) scale(0.3)`, opacity: 0 },
        ],
        { duration: 620, easing: 'cubic-bezier(0.4, 0, 0.2, 1)', fill: 'forwards' }
      )

      anim.onfinish = () => {
        heart.remove()
        navLink.animate(
          [
            { transform: 'scale(1)', color: 'inherit' },
            { transform: 'scale(1.35)', color: '#e8444a' },
            { transform: 'scale(1)', color: 'inherit' },
          ],
          { duration: 320, easing: 'ease-out' }
        )
      }
    }
  }

  const videoModal = document.querySelector('[data-video-modal]')
  const videoFrame = document.querySelector('[data-video-frame]')
  const videoTitle = document.querySelector('[data-video-modal-title]')

  if (
    videoModal instanceof HTMLDialogElement &&
    videoFrame instanceof HTMLIFrameElement &&
    videoTitle instanceof HTMLElement
  ) {
    function closeVideoModal() {
      videoFrame.src = ''
      videoModal.close()
    }

    document.querySelectorAll('[data-video-trigger]').forEach((trigger) => {
      trigger.addEventListener('click', () => {
        if (!(trigger instanceof HTMLButtonElement)) return
        const embedUrl = trigger.dataset.videoEmbed
        const title = trigger.dataset.videoTitle || 'Athlete video'
        if (!embedUrl) return
        videoTitle.textContent = title
        videoFrame.src = embedUrl
        videoModal.showModal()
      })
    })

    document.querySelectorAll('[data-video-close]').forEach((button) => {
      button.addEventListener('click', closeVideoModal)
    })

    videoModal.addEventListener('cancel', (event) => {
      event.preventDefault()
      closeVideoModal()
    })
  }
</script>
