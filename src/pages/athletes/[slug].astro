---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getAthletes } from '../../lib/athlete-repository'
import { findAthleteBySlug } from '../../lib/athletes'
import { formatBioHtml } from '../../lib/rich-text'
import { publicCacheHeader } from '../../lib/http-cache'

Astro.response.headers.set('Cache-Control', publicCacheHeader({ sMaxAge: 300, staleWhileRevalidate: 3600 }))
const { slug } = Astro.params
const athletes = await getAthletes()
const athlete = findAthleteBySlug(slug, athletes)
const verseUrl = athlete?.verse
  ? `https://www.bible.com/search/bible?q=${encodeURIComponent(athlete.verse)}`
  : ''
---

<BaseLayout
  title={`${athlete?.name || 'Athlete Profile'} | Glory & Game`}
  description={athlete?.bio || 'Athlete profile on Glory & Game.'}
  pathname="/players/"
>
  <div data-athlete-detail>
    {athlete ? (
      <>
        <article class="panel detail">
          <div class="detail__media">
            <img src={athlete.image} alt={athlete.name} loading="lazy" decoding="async" />
            <div class="hero__actions detail__media-actions">
              <a class="button-secondary" href="/players/">Back to Players</a>
            </div>
          </div>
          <div class="detail__copy">
            <div class="detail__topbar">
              <div>
                <p class="eyebrow">Athlete Profile</p>
              </div>
              <button class="button-secondary detail__card-cta" type="button" data-open-player-card>
                <span class="detail__card-cta-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                  </svg>
                </span>
                3D Player Card
              </button>
            </div>
            <h1>{athlete.name}</h1>
            <p class="meta">{athlete.sport} • {athlete.team}</p>
            <div class="detail__bio" set:html={formatBioHtml(athlete.bio)} />
            <div class="verse-row">
              <blockquote>{athlete.verse}</blockquote>
              {verseUrl && (
                <p class="verse-link">
                  <a href={verseUrl} target="_blank" rel="noreferrer">
                    Read on Bible.com
                  </a>
                </p>
              )}
            </div>
            {(athlete.instagram || athlete.x) && (
              <div class="profile-socials">
                <p class="profile-socials__label">Follow</p>
                <div class="profile-socials__links">
                  {athlete.instagram && (
                    <a
                      class="social-button social-button--instagram"
                      href={athlete.instagram}
                      target="_blank"
                      rel="noreferrer"
                    >
                      <span class="social-button__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" role="img" focusable="false">
                          <path
                            d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 1.8A3.7 3.7 0 0 0 3.8 7.5v9a3.7 3.7 0 0 0 3.7 3.7h9a3.7 3.7 0 0 0 3.7-3.7v-9a3.7 3.7 0 0 0-3.7-3.7h-9Zm9.55 1.35a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8A3.2 3.2 0 1 0 12 15.2 3.2 3.2 0 0 0 12 8.8Z"
                            fill="currentColor"
                          />
                        </svg>
                      </span>
                      Instagram
                    </a>
                  )}
                  {athlete.x && (
                    <a class="social-button social-button--x" href={athlete.x} target="_blank" rel="noreferrer">
                      <span class="social-button__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" role="img" focusable="false">
                          <path
                            d="M18.9 2H22l-6.78 7.75L23 22h-6.1l-4.77-6.92L6.08 22H3l7.27-8.32L1 2h6.25l4.31 6.28L18.9 2Zm-1.07 18.13h1.69L6.33 3.77H4.51l13.32 16.36Z"
                            fill="currentColor"
                          />
                        </svg>
                      </span>
                      X
                    </a>
                  )}
                </div>
              </div>
            )}
          </div>
        </article>

        <dialog class="player-card-modal" data-player-card-modal>
          <div class="player-card-modal__shell">
            <video
              class="player-card-modal__video"
              autoplay
              muted
              playsinline
              poster="/assets/stage.jpg"
              aria-hidden="true"
            >
              <source src="/assets/stage.mp4" type="video/mp4" />
            </video>
            <div class="player-card-modal__topbar">
              <div>
                <p class="eyebrow">Player Card</p>
                <h2>{athlete.name}</h2>
              </div>
              <div class="player-card-modal__actions">
                <button class="button-secondary player-card-modal__action" type="button" data-flip-player-card>
                  Flip Card
                </button>
                <button class="button-secondary player-card-modal__action" type="button" data-share-player-card>
                  Share Card
                </button>
                <button class="player-card-modal__close" type="button" data-close-player-card aria-label="Close player card">
                  Close
                </button>
              </div>
            </div>

            <div class="player-card-viewer">
              <div class="player-card-stage" data-player-card-stage>
                <article class="player-card-3d" data-player-card data-flipped="false">
                  <div class="player-card-face player-card-face--front">
                    <div class="player-card-face__glow"></div>
                    <div class="player-card-face__header">
                      <span class="player-card-face__brand">Glory &amp; Game</span>
                    </div>
                    <div class="player-card-face__media">
                      <img src={athlete.image} alt={athlete.name} loading="lazy" decoding="async" />
                    </div>
                    <div class="player-card-face__footer">
                      <p class="player-card-face__name">{athlete.name}</p>
                      <p class="player-card-face__verse">{athlete.verse}</p>
                    </div>
                  </div>

                  <div class="player-card-face player-card-face--back">
                    <div class="player-card-face__back-content">
                      <div class="player-card-face__back-hero">
                        <h3>{athlete.name}</h3>
                        <p class="player-card-face__back-meta">{athlete.sport} • {athlete.team}</p>
                      </div>

                      <p class="player-card-face__back-copy">{athlete.bio}</p>

                      <div class="player-card-face__verse-block">
                        <p class="player-card-face__back-verse">{athlete.verse}</p>
                        {verseUrl && (
                          <a
                            class="player-card-face__verse-link"
                            href={verseUrl}
                            target="_blank"
                            rel="noreferrer"
                          >
                            Read on Bible.com
                          </a>
                        )}
                      </div>

                      {(athlete.instagram || athlete.x) && (
                        <div class="player-card-face__follow">
                          <p class="player-card-face__follow-label">Follow</p>
                          <div class="player-card-face__follow-links">
                            {athlete.instagram && (
                              <a
                                class="social-button social-button--instagram"
                                href={athlete.instagram}
                                target="_blank"
                                rel="noreferrer"
                              >
                                <span class="social-button__icon" aria-hidden="true">
                                  <svg viewBox="0 0 24 24" role="img" focusable="false">
                                    <path
                                      d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 1.8A3.7 3.7 0 0 0 3.8 7.5v9a3.7 3.7 0 0 0 3.7 3.7h9a3.7 3.7 0 0 0 3.7-3.7v-9a3.7 3.7 0 0 0-3.7-3.7h-9Zm9.55 1.35a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8A3.2 3.2 0 1 0 12 15.2 3.2 3.2 0 0 0 12 8.8Z"
                                      fill="currentColor"
                                    />
                                  </svg>
                                </span>
                                Instagram
                              </a>
                            )}
                            {athlete.x && (
                              <a
                                class="social-button social-button--x"
                                href={athlete.x}
                                target="_blank"
                                rel="noreferrer"
                              >
                                <span class="social-button__icon" aria-hidden="true">
                                  <svg viewBox="0 0 24 24" role="img" focusable="false">
                                    <path
                                      d="M18.9 2H22l-6.78 7.75L23 22h-6.1l-4.77-6.92L6.08 22H3l7.27-8.32L1 2h6.25l4.31 6.28L18.9 2Zm-1.07 18.13h1.69L6.33 3.77H4.51l13.32 16.36Z"
                                      fill="currentColor"
                                    />
                                  </svg>
                                </span>
                                X
                              </a>
                            )}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                </article>
              </div>
              <p class="feedback player-card-share-feedback" data-player-card-feedback hidden></p>
            </div>
          </div>
        </dialog>
      </>
    ) : (
      <article class="panel detail">
        <div class="detail__media">
          <img src="/assets/athletes/default-athlete.jpg" alt="Athlete not found" />
        </div>
        <div class="detail__copy">
          <p class="eyebrow">Athlete Profile</p>
          <h1>Athlete Not Found</h1>
          <p class="meta">Profile • Glory &amp; Game</p>
          <p>We could not find this athlete yet. Browse the directory or submit a new profile.</p>
          <blockquote>Colossians 3:23-24</blockquote>
          <div class="hero__actions">
            <a class="button" href="/submit-profile/">Submit an Athlete</a>
            <a class="button-secondary" href="/players/">Back to Players</a>
          </div>
        </div>
      </article>
    )}
  </div>
</BaseLayout>

{athlete && (
  <script define:vars={{ athleteName: athlete.name, athleteSport: athlete.sport, athleteTeam: athlete.team }} type="module">
    const openButton = document.querySelector('[data-open-player-card]')
    const closeButton = document.querySelector('[data-close-player-card]')
    const modal = document.querySelector('[data-player-card-modal]')
    const card = document.querySelector('[data-player-card]')
    const stage = document.querySelector('[data-player-card-stage]')
    const flipButton = document.querySelector('[data-flip-player-card]')
    const shareButton = document.querySelector('[data-share-player-card]')
    const shareFeedback = document.querySelector('[data-player-card-feedback]')

    if (
      openButton instanceof HTMLButtonElement &&
      closeButton instanceof HTMLButtonElement &&
      modal instanceof HTMLDialogElement &&
      card instanceof HTMLElement &&
      stage instanceof HTMLElement &&
      flipButton instanceof HTMLButtonElement &&
      shareButton instanceof HTMLButtonElement &&
      shareFeedback instanceof HTMLElement
    ) {
      const shareTitle = `${athleteName} Player Card`
      const shareText = `${athleteName} • ${athleteSport} • ${athleteTeam}`
      let animationFrame = 0
      let currentRotateX = 0
      let currentRotateY = 0
      let currentGlareX = 50
      let currentGlareY = 20
      let targetRotateX = 0
      let targetRotateY = 0
      let targetGlareX = 50
      let targetGlareY = 20

      function renderTilt() {
        currentRotateX += (targetRotateX - currentRotateX) * 0.14
        currentRotateY += (targetRotateY - currentRotateY) * 0.14
        currentGlareX += (targetGlareX - currentGlareX) * 0.14
        currentGlareY += (targetGlareY - currentGlareY) * 0.14

        card.style.setProperty('--card-rotate-x', `${currentRotateX.toFixed(2)}deg`)
        card.style.setProperty('--card-rotate-y', `${currentRotateY.toFixed(2)}deg`)
        card.style.setProperty('--card-glare-x', `${currentGlareX.toFixed(1)}%`)
        card.style.setProperty('--card-glare-y', `${currentGlareY.toFixed(1)}%`)

        const shouldContinue =
          Math.abs(targetRotateX - currentRotateX) > 0.02 ||
          Math.abs(targetRotateY - currentRotateY) > 0.02 ||
          Math.abs(targetGlareX - currentGlareX) > 0.05 ||
          Math.abs(targetGlareY - currentGlareY) > 0.05

        if (shouldContinue) {
          animationFrame = window.requestAnimationFrame(renderTilt)
        } else {
          animationFrame = 0
        }
      }

      function scheduleTilt() {
        if (!animationFrame) {
          animationFrame = window.requestAnimationFrame(renderTilt)
        }
      }

      function getShareUrl() {
        const url = new URL(window.location.href)
        url.searchParams.set('card', '3d')
        url.searchParams.set('side', card.dataset.flipped === 'true' ? 'back' : 'front')
        return url.toString()
      }

      function syncCardUrl() {
        const url = new URL(window.location.href)

        if (modal.open) {
          url.searchParams.set('card', '3d')
          url.searchParams.set('side', card.dataset.flipped === 'true' ? 'back' : 'front')
        } else {
          url.searchParams.delete('card')
          url.searchParams.delete('side')
        }

        window.history.replaceState({}, '', url)
      }

      function setFlipped(nextValue) {
        card.dataset.flipped = nextValue ? 'true' : 'false'
        if (modal.open) syncCardUrl()
      }

      function resetTilt() {
        targetRotateX = 0
        targetRotateY = 0
        targetGlareX = 50
        targetGlareY = 20
        scheduleTilt()
      }

      function showShareFeedback(message, tone = 'success') {
        shareFeedback.dataset.tone = tone
        shareFeedback.textContent = message
        shareFeedback.hidden = false
        window.setTimeout(() => {
          shareFeedback.hidden = true
        }, 2200)
      }

      openButton.addEventListener('click', () => {
        modal.showModal()
        resetTilt()
        syncCardUrl()
      })

      closeButton.addEventListener('click', () => {
        modal.close()
      })

      modal.addEventListener('click', (event) => {
        if (event.target === modal) {
          modal.close()
        }
      })

      flipButton.addEventListener('click', () => {
        setFlipped(card.dataset.flipped !== 'true')
      })

      card.addEventListener('click', (event) => {
        const target = event.target

        if (target instanceof Element && target.closest('a, button')) {
          return
        }

        setFlipped(card.dataset.flipped !== 'true')
      })

      stage.addEventListener('pointermove', (event) => {
        const rect = stage.getBoundingClientRect()
        const x = (event.clientX - rect.left) / rect.width
        const y = (event.clientY - rect.top) / rect.height
        targetRotateY = (x - 0.5) * 26
        targetRotateX = (0.5 - y) * 24
        targetGlareX = x * 100
        targetGlareY = y * 100
        scheduleTilt()
      })

      stage.addEventListener('pointerleave', () => {
        resetTilt()
      })

      shareButton.addEventListener('click', async () => {
        const shareUrl = getShareUrl()

        try {
          if (navigator.share) {
            await navigator.share({
              title: shareTitle,
              text: shareText,
              url: shareUrl,
            })
            showShareFeedback('Player card shared.', 'success')
            return
          }

          await navigator.clipboard.writeText(`${shareTitle}\n${shareText}\n${shareUrl}`)
          showShareFeedback('Share link copied to clipboard.', 'success')
        } catch (error) {
          showShareFeedback('Could not share this card right now.', 'error')
        }
      })

      modal.addEventListener('close', () => {
        resetTilt()
        syncCardUrl()
      })

      const params = new URLSearchParams(window.location.search)
      if (params.get('card') === '3d') {
        setFlipped(params.get('side') === 'back')
        modal.showModal()
        resetTilt()
        syncCardUrl()
      }
    }
  </script>
)}
