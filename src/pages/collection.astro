---
import BaseLayout from '../layouts/BaseLayout.astro'
import PlayerCardPreview from '../components/PlayerCardPreview.astro'
import { getAthletes } from '../lib/athlete-repository'
import { findAthleteBySlug } from '../lib/athletes'
import { getUserFavorites } from '../lib/clerk-user'
import { cardDesigns } from '../lib/card-designs'

const DESIGN_SWATCH: Record<string, string> = {
  'holo-refractor':  'conic-gradient(from 0deg, #ff0080, #ff8c00, #ffee00, #40e0d0, #7b2fff, #ff0080)',
  'classic-holo':    'linear-gradient(135deg, #00e5ff 0%, #ff4d9e 100%)',
  'cosmos':          'radial-gradient(circle, #3d1a78 0%, #0a0015 100%)',
  'gold-sovereign':  'linear-gradient(135deg, #c9a227 0%, #8b6914 100%)',
  'jersey-patch':    'linear-gradient(135deg, #4b5563 0%, #9ca3af 100%)',
  'comic':           'linear-gradient(135deg, #e03030 0%, #1d4ed8 100%)',
  'void':            'linear-gradient(135deg, #0a001a 0%, #5b21b6 100%)',
  'street':          'linear-gradient(135deg, #1a1a1a 0%, #39ff14 100%)',
  'full-art':        'linear-gradient(135deg, #7f1d1d 0%, #1e1e2e 100%)',
  'prizm':           'linear-gradient(135deg, #0ea5e9 0%, #d946ef 100%)',
  'solar':           'linear-gradient(135deg, #f59e0b 0%, #dc2626 100%)',
  'aurora':          'linear-gradient(135deg, #064e3b 0%, #5b21b6 100%)',
  'chrome':          'linear-gradient(135deg, #374151 0%, #d1d5db 100%)',
}

const { userId } = Astro.locals.auth()

const favorites = userId ? await getUserFavorites(userId) : []
const allAthletes = userId ? await getAthletes() : []
const favoriteAthletes = favorites
  .map((slug) => findAthleteBySlug(slug, allAthletes))
  .filter(Boolean)

// Show a random athlete as the pack-opening teaser
const teaserAthletes = userId ? [] : await getAthletes()
const teaserAthlete = teaserAthletes[Math.floor(Math.random() * teaserAthletes.length)]
const teaserDesign = cardDesigns.slice(0, 6)[Math.floor(Math.random() * 6)].id
---

<BaseLayout
  title="My Cards | Glory & Game"
  description="Your personal Glory & Game card collection."
  pathname="/collection/"
>
  <section class="panel collection-panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Your Collection</p>
        <h1>My Cards</h1>
        {favoriteAthletes.length > 0 && (
          <p><span>{favoriteAthletes.length}</span> card{favoriteAthletes.length === 1 ? '' : 's'} saved.</p>
        )}
      </div>
      <a class="button" href="/players/">Browse Players</a>
    </div>

    {!userId ? (
      <div class="collection-empty">
        <div class="pack-reveal-cta">
          <h2>Sign up to start collecting</h2>
          <p>Create a free account to save your favourite athlete cards and build your personal collection.</p>
          <div class="hero__actions">
            <a class="button-secondary detail__card-cta" href="/sign-up">
              <span class="detail__card-cta-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
              </span>
              Sign up
            </a>
          </div>
        </div>
        <div class="pack-reveal peel" data-pack-reveal>
          <div class="peel-top">
            <img src="/assets/fabric/card-package.png" alt="Glory & Game card pack" draggable="false" />
          </div>
          <div class="peel-back"></div>
          <div class="peel-bottom">
            <PlayerCardPreview athlete={teaserAthlete} design={teaserDesign} />
          </div>
          <button class="pack-reveal__tap-hint" data-pack-trigger type="button" aria-label="Open pack">
            <span>Tap to rip open</span>
          </button>
        </div>
      </div>
    ) : favoriteAthletes.length === 0 ? (
      <div class="collection-empty">
        <div class="collection-empty__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
        </div>
        <h2>No cards saved yet</h2>
        <p>Browse athletes and tap the heart on their profile to save cards to your collection.</p>
        <a class="button" href="/players/">Browse Players</a>
      </div>
    ) : (
      <div class="collection-grid">
        {favoriteAthletes.map((athlete) => (
          <div class="collection-grid__item" data-collection-item data-slug={athlete.slug}>
            <PlayerCardPreview athlete={athlete} />
            <div class="card-design-picker" data-design-picker aria-label="Change card design">
              {cardDesigns.map((d) => (
                <button
                  class="card-design-picker__dot"
                  data-pick-design={d.id}
                  title={d.label}
                  aria-label={`Switch to ${d.label}`}
                  style={`background: ${DESIGN_SWATCH[d.id]}`}
                />
              ))}
            </div>
            <button
              class="favorite-btn favorite-btn--on-card favorite-btn--active"
              type="button"
              aria-label={`Remove ${athlete.name} from My Cards`}
              data-favorite-slug={athlete.slug}
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
              </svg>
            </button>
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .card-design-picker {
    display: flex;
    gap: 5px;
    justify-content: center;
    align-items: center;
    margin-top: 10px;
    opacity: 0;
    translate: 0 4px;
    transition: opacity 0.18s ease, translate 0.18s ease;
    pointer-events: none;
  }
  .collection-grid__item:hover .card-design-picker {
    opacity: 1;
    translate: 0 0;
    pointer-events: auto;
  }
  .card-design-picker__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid transparent;
    padding: 0;
    cursor: pointer;
    transition: transform 0.12s ease, border-color 0.12s ease, outline-offset 0.12s ease;
    outline: 1.5px solid transparent;
    outline-offset: 0px;
  }
  .card-design-picker__dot:hover {
    transform: scale(1.5);
  }
  .card-design-picker__dot[data-active] {
    outline-color: rgba(255, 255, 255, 0.7);
    outline-offset: 2px;
    transform: scale(1.2);
  }

  .section-heading {
    position: relative;
    z-index: 10;
    align-items: flex-start;
  }


  /* ── Pack-reveal peel effect ────────────────────────────────── */
  .pack-reveal {
    width: 339px;
    height: 605px;
    cursor: pointer;
    margin: 0;
    flex-shrink: 0;
  }

  .pack-reveal-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 16px;
    max-width: 320px;
  }

  .pack-reveal-cta h2 {
    color: var(--text);
    font-size: 1.8rem;
    margin: 0;
    line-height: 1.1;
  }

  .pack-reveal-cta p {
    margin: 0;
    line-height: 1.6;
    max-width: 28ch;
  }

  .pack-reveal__tap-hint {
    position: absolute;
    z-index: 10;
    bottom: 16px;
    left: 50%;
    translate: -50% 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 20px;
    padding: 6px 16px;
    color: rgba(245, 246, 242, 0.8);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    cursor: pointer;
    animation: pack-hint-pulse 2s ease-in-out infinite;
    transition: opacity 0.3s ease;
  }

  .pack-reveal[data-opened] .pack-reveal__tap-hint {
    opacity: 0;
    pointer-events: none;
  }

  @keyframes pack-hint-pulse {
    0%, 100% { opacity: 0.7; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(-3px); }
  }

  @media (max-width: 720px) {
    .section-heading {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }

    .section-heading .button {
      min-height: auto;
      padding: 6px 12px;
      font-size: 0.6rem;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .pack-reveal {
      width: min(280px, 80vw);
      height: calc(min(280px, 80vw) * 1.785);
    }

    .pack-reveal-cta {
      align-items: center;
      text-align: center;
    }

    .pack-reveal-cta h2 {
      font-size: 1.5rem;
    }

    .pack-reveal__tap-hint {
      bottom: auto;
      top: -44px;
    }
  }

</style>

<style is:global>
  /* peel.js base styles */
  .peel { position: relative; opacity: 0; }
  .peel-ready { opacity: 1; }
  .peel-svg-clip-element { position: absolute; top: -10000px; left: -10000px; width: 1px; height: 1px; opacity: 0; }
  .peel-layer {
    position: absolute; z-index: 1; width: 100%; height: 100%;
    top: 0; right: 0; bottom: 0; left: 0;
    user-select: none; transform-origin: top left;
  }

  /* Override peel.js default backgrounds */
  .pack-reveal .peel-top {
    background: none !important;
  }
  .pack-reveal .peel-top img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
    pointer-events: none;
  }
  .pack-reveal .peel-back {
    background: linear-gradient(135deg, #2a2d26 0%, #1a1c17 100%) !important;
  }
  .pack-reveal .peel-bottom {
    background: none !important;
    overflow: visible;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 50px 40px;
  }
</style>

<script>
  // ── Pack-reveal peel.js interaction ───────────────────────────────
  import { Peel } from 'peel.js'

  const packReveal = document.querySelector('[data-pack-reveal]')
  if (packReveal instanceof HTMLElement) {
    const w = packReveal.offsetWidth
    const h = packReveal.offsetHeight

    const peel = new Peel(packReveal, {
      corner: { x: w, y: 0 },
      topShadow: false,
      backReflection: false,
      backShadow: false,
      bottomShadow: false,
      fadeThreshold: 0.7,
    })

    // Bezier path: from top-right corner curving down to bottom-left
    peel.setPeelPath(w, 0, w * 0.3, 0, 0, h, w * -0.5, h)
    peel.setTimeAlongPath(0)

    let opened = false
    let animating = false

    function animatePeel() {
      if (opened || animating) return
      opened = true
      animating = true
      packReveal.dataset.opened = ''

      const duration = 1200
      const start = performance.now()

      function tick(now) {
        const elapsed = now - start
        // easeInOut cubic
        let t = Math.min(elapsed / duration, 1)
        t = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2

        peel.setTimeAlongPath(t)

        if (elapsed < duration) {
          requestAnimationFrame(tick)
        } else {
          animating = false
          // Remove peel layers so the card is fully interactive
          packReveal.querySelectorAll('.peel-layer, .peel-svg-clip-element').forEach((el) => {
            if (el instanceof HTMLElement) {
              // Keep anything containing the bottom layer
              if (el.querySelector('.peel-bottom') || el.classList.contains('peel-bottom')) {
                el.style.clipPath = 'none'
                el.style.webkitClipPath = 'none'
                el.style.overflow = 'visible'
              } else {
                el.style.display = 'none'
              }
            }
          })
          // Free the bottom layer — animate the card expanding to fill
          const bottom = packReveal.querySelector('.peel-bottom')
          if (bottom instanceof HTMLElement) {
            bottom.style.transition = 'padding 0.6s cubic-bezier(0.16, 1, 0.3, 1)'
            bottom.style.position = 'relative'
            bottom.style.clipPath = 'none'
            bottom.style.overflow = 'visible'
            bottom.style.zIndex = '10'
            // Trigger the padding transition on next frame
            requestAnimationFrame(() => {
              bottom.style.padding = '0'
            })
          }
          // Free everything from clipping
          packReveal.style.overflow = 'visible'
          // Clear clip-path on any parent wrappers peel.js created
          let el = packReveal.querySelector('.peel-bottom')
          while (el && el !== packReveal) {
            if (el instanceof HTMLElement) {
              el.style.clipPath = 'none'
              el.style.webkitClipPath = 'none'
              el.style.overflow = 'visible'
            }
            el = el.parentElement
          }
          // Also free the card stage and collection panel from clipping
          packReveal.querySelectorAll('.card-preview__stage, .peel-bottom, .collection-empty, .collection-panel').forEach((c) => {
            if (c instanceof HTMLElement) c.style.overflow = 'visible'
          })
          const card = packReveal.querySelector('[data-player-card]')
          const scaler = packReveal.querySelector('.player-card-3d-scaler')
          if (card instanceof HTMLElement && scaler instanceof HTMLElement) {
            document.body.addEventListener('mousemove', (e) => {
              const rect = scaler.getBoundingClientRect()
              const x = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width))
              const y = Math.max(0, Math.min(1, (e.clientY - rect.top) / rect.height))
              const rotX = (0.5 - y) * 22
              const rotY = (x - 0.5) * 22
              const hyp = Math.min(Math.sqrt((x - 0.5) ** 2 + (y - 0.5) ** 2) * 2, 1)
              card.style.setProperty('--card-rotate-x', `${rotX.toFixed(2)}deg`)
              card.style.setProperty('--card-rotate-y', `${rotY.toFixed(2)}deg`)
              card.style.setProperty('--card-pos-x', `${(x * 100).toFixed(1)}%`)
              card.style.setProperty('--card-pos-y', `${(y * 100).toFixed(1)}%`)
              card.style.setProperty('--card-pos-x-invert', `${((1 - x) * 100).toFixed(1)}%`)
              card.style.setProperty('--card-pos-y-invert', `${((1 - y) * 100).toFixed(1)}%`)
              card.style.setProperty('--card-glare-x', `${(x * 100).toFixed(1)}%`)
              card.style.setProperty('--card-glare-y', `${(y * 100).toFixed(1)}%`)
              card.style.setProperty('--card-hyp', hyp.toFixed(3))
              card.style.setProperty('--card-opacity', '1')
              card.style.setProperty('--pointer-from-left', x.toFixed(3))
              card.style.setProperty('--pointer-from-top', y.toFixed(3))
              card.style.setProperty('--pointer-x', `${(x * 100).toFixed(1)}%`)
              card.style.setProperty('--pointer-y', `${(y * 100).toFixed(1)}%`)
            })
            document.body.addEventListener('mouseleave', () => {
              const rotX = (0.5 - 0.38) * 22
              const rotY = (0.62 - 0.5) * 22
              const hyp = Math.min(Math.sqrt((0.62 - 0.5) ** 2 + (0.38 - 0.5) ** 2) * 2, 1)
              card.style.setProperty('--card-rotate-x', `${rotX.toFixed(2)}deg`)
              card.style.setProperty('--card-rotate-y', `${rotY.toFixed(2)}deg`)
              card.style.setProperty('--card-pos-x', '62.0%')
              card.style.setProperty('--card-pos-y', '38.0%')
              card.style.setProperty('--card-pos-x-invert', '38.0%')
              card.style.setProperty('--card-pos-y-invert', '62.0%')
              card.style.setProperty('--card-glare-x', '62.0%')
              card.style.setProperty('--card-glare-y', '38.0%')
              card.style.setProperty('--card-hyp', hyp.toFixed(3))
              card.style.setProperty('--pointer-from-left', '0.620')
              card.style.setProperty('--pointer-from-top', '0.380')
              card.style.setProperty('--pointer-x', '62.0%')
              card.style.setProperty('--pointer-y', '38.0%')
            })
          }
        }
      }
      requestAnimationFrame(tick)
    }

    packReveal.addEventListener('click', animatePeel)
  }

  // ── Init design from localStorage & wire design picker ───────────
  document.querySelectorAll('[data-collection-item]').forEach((item) => {
    if (!(item instanceof HTMLElement)) return
    const slug = item.dataset.slug
    if (!slug) return

    const card = item.querySelector('[data-player-card]')
    if (!(card instanceof HTMLElement)) return

    const storageKey = `glory-and-game:player-card-design:${slug}`
    const saved = localStorage.getItem(storageKey)
    if (saved) card.dataset.design = saved

    const activeDesign = () => card.dataset.design ?? 'holo-refractor'

    function syncDots() {
      item.querySelectorAll('[data-pick-design]').forEach((dot) => {
        if (!(dot instanceof HTMLElement)) return
        if (dot.dataset.pickDesign === activeDesign()) {
          dot.dataset.active = ''
        } else {
          delete dot.dataset.active
        }
      })
    }
    syncDots()

    item.querySelectorAll('[data-pick-design]').forEach((dot) => {
      dot.addEventListener('click', (e) => {
        e.preventDefault()
        e.stopPropagation()
        if (!(dot instanceof HTMLElement)) return
        const design = dot.dataset.pickDesign
        if (!design) return
        card.dataset.design = design
        localStorage.setItem(storageKey, design)
        syncDots()
      })
    })
  })

  // ── Init HC mask on each card preview ─────────────────────────────
  document.querySelectorAll('[data-card-preview]').forEach((preview) => {
    const card = preview.querySelector('[data-player-card]')
    if (!(card instanceof HTMLElement)) return

    // Apply HC mask
    ;['.ch-card', '.design-card'].forEach((sel) => {
      const el = preview.querySelector(sel)
      if (el instanceof HTMLElement) {
        const url = el.dataset.maskUrl
        if (url) el.style.setProperty('--mask', `url("${url}")`)
      }
    })

    // Resting tilt (slight angle so the holo effect is visible)
    setCardVars(card, 0.62, 0.38)
    bindCardGyro(card)

    // ── Hover interaction ──────────────────────────────────────────
    // Use the scaler's getBoundingClientRect — it returns visual bounds
    // (post-transform), so coordinates are accurate to the rendered card.
    const scaler = preview.querySelector('.player-card-3d-scaler')
    const stage = preview.querySelector('.card-preview__stage')
    if (!(scaler instanceof HTMLElement) || !(stage instanceof HTMLElement)) return

    stage.addEventListener('mousemove', (e) => {
      if (card.dataset.motionActive === 'true') return
      const rect = scaler.getBoundingClientRect()
      const x = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width))
      const y = Math.max(0, Math.min(1, (e.clientY - rect.top) / rect.height))
      setCardVars(card, x, y)
    })

    stage.addEventListener('mouseleave', () => {
      if (card.dataset.motionActive === 'true') return
      setCardVars(card, 0.62, 0.38)
    })

    function bindCardGyro(el) {
      const canUseMotion = window.matchMedia?.('(pointer: coarse)').matches && 'DeviceOrientationEvent' in window
      if (!canUseMotion) return

      let motionStarted = false
      let latestMotion = null
      let frame = 0
      let currentX = 0.62
      let currentY = 0.38

      const clamp = (value) => Math.max(0, Math.min(1, value))

      const tick = () => {
        frame = 0
        if (!latestMotion) return

        currentX += (latestMotion.x - currentX) * 0.16
        currentY += (latestMotion.y - currentY) * 0.16
        setCardVars(el, currentX, currentY)

        if (Math.abs(latestMotion.x - currentX) > 0.001 || Math.abs(latestMotion.y - currentY) > 0.001) {
          frame = window.requestAnimationFrame(tick)
        }
      }

      const handleOrientation = (event) => {
        if (typeof event.gamma !== 'number' || typeof event.beta !== 'number') return

        latestMotion = {
          x: clamp(0.5 + (event.gamma / 22)),
          y: clamp(0.5 + (event.beta / 30)),
        }

        if (!frame) frame = window.requestAnimationFrame(tick)
      }

      const startMotion = () => {
        if (motionStarted) return
        motionStarted = true
        el.dataset.motionActive = 'true'
        window.addEventListener('deviceorientation', handleOrientation, { passive: true })
      }

      const requestMotion = () => {
        const DeviceOrientation = window.DeviceOrientationEvent
        if (typeof DeviceOrientation?.requestPermission !== 'function') {
          startMotion()
          return
        }

        window.__ggDeviceOrientationPermission ??= DeviceOrientation.requestPermission()
          .then((state) => state === 'granted')
          .catch(() => false)

        window.__ggDeviceOrientationPermission.then((granted) => {
          if (granted) startMotion()
        })
      }

      if (typeof window.DeviceOrientationEvent?.requestPermission === 'function') {
        window.addEventListener('pointerdown', requestMotion, { once: true, passive: true })
        window.addEventListener('touchstart', requestMotion, { once: true, passive: true })
      } else {
        startMotion()
      }
    }

    function setCardVars(el, x, y) {
      const rotX = (0.5 - y) * 22
      const rotY = (x - 0.5) * 22
      const hyp = Math.min(Math.sqrt((x - 0.5) ** 2 + (y - 0.5) ** 2) * 2, 1)
      el.style.setProperty('--card-rotate-x', `${rotX.toFixed(2)}deg`)
      el.style.setProperty('--card-rotate-y', `${rotY.toFixed(2)}deg`)
      el.style.setProperty('--card-pos-x', `${(x * 100).toFixed(1)}%`)
      el.style.setProperty('--card-pos-y', `${(y * 100).toFixed(1)}%`)
      el.style.setProperty('--card-pos-x-invert', `${((1 - x) * 100).toFixed(1)}%`)
      el.style.setProperty('--card-pos-y-invert', `${((1 - y) * 100).toFixed(1)}%`)
      el.style.setProperty('--card-glare-x', `${(x * 100).toFixed(1)}%`)
      el.style.setProperty('--card-glare-y', `${(y * 100).toFixed(1)}%`)
      el.style.setProperty('--card-hyp', hyp.toFixed(3))
      el.style.setProperty('--card-opacity', '1')
      el.style.setProperty('--pointer-from-left', x.toFixed(3))
      el.style.setProperty('--pointer-from-top', y.toFixed(3))
      el.style.setProperty('--pointer-x', `${(x * 100).toFixed(1)}%`)
      el.style.setProperty('--pointer-y', `${(y * 100).toFixed(1)}%`)
    }
  })

  // ── Unfavorite from collection ─────────────────────────────────────
  document.querySelectorAll('[data-favorite-slug]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const slug = btn.dataset.favoriteSlug
      try {
        const res = await fetch('/api/favorites', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug }),
        })
        if (res.ok) {
          const item = btn.closest('[data-collection-item]')
          if (item instanceof HTMLElement) {
            item.style.transition = 'opacity 0.3s, transform 0.3s'
            item.style.opacity = '0'
            item.style.transform = 'scale(0.92)'
            setTimeout(() => {
              item.remove()
              if (!document.querySelector('[data-collection-item]')) {
                location.reload()
              }
            }, 300)
          }
        }
      } catch {
        // silently fail
      }
    })
  })
</script>
