---
import { SignIn } from '@clerk/astro/components'
import siteNoiseScript from '../scripts/site-noise.js?url'

const heroImages = [
  'braden-collum-9HI8UJMSdZA-unsplash.jpg',
  'courtney-cook-SsIIw_MET0E-unsplash.jpg',
  'emilio-garcia-AWdCgDDedH0-unsplash.jpg',
  'gentrit-sylejmani-JjUyjE-oEbM-unsplash.jpg',
  'geoff-scott-8lUTnkZXZSA-unsplash.jpg',
  'ilya-shishikhin-bpz-MQJDJuA-unsplash.jpg',
  'jannes-glas-0NaQQsLWLkA-unsplash.jpg',
  'john-arano-h4i9G-de7Po-unsplash.jpg',
  'lan-gao-MpjJKR-P18I-unsplash.jpg',
  'nathanael-desmeules-mWPdKMZPEpU-unsplash.jpg',
  'sandro-schuh-HgwY_YQ1m0w-unsplash.jpg',
  'sincerely-media-oC32cy4x-ZA-unsplash.jpg',
  'taylor-smith-selWWrPDkoc-unsplash.jpg',
  'valentin-balan-k0aVMMZwqtU-unsplash.jpg',
]
const hero = heroImages[Math.floor(Math.random() * heroImages.length)]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign In — Glory & Game</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@800&family=Manrope:wght@400;500;600;700;800&display=swap"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #111315;
        font-family: 'Manrope', sans-serif;
        padding: 2rem;
        position: relative;
        overflow: hidden;
      }

      .site-noise {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
        opacity: 0.4;
      }

      .hero-bg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        opacity: 0.18;
        filter: blur(6px) grayscale(30%);
        scale: 1.05;
        z-index: 0;
        pointer-events: none;
      }

      .glow {
        position: fixed;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(227, 196, 116, 0.08) 0%, transparent 70%);
        top: 50%;
        left: 50%;
        translate: -50% -50%;
        pointer-events: none;
        z-index: 0;
      }

      .shell {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        width: 100%;
        max-width: 480px;
      }

      .brand {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        text-decoration: none;
      }

      .brand__eyebrow {
        font-family: 'Manrope', sans-serif;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #e3c474;
      }

      .brand__name {
        font-family: 'Archivo', 'Avenir Next', 'Segoe UI', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #ffffff;
        line-height: 1;
      }

      .brand__logo {
        width: 56px;
        height: auto;
        margin-bottom: 0.5rem;
        opacity: 0.9;
      }
    </style>
  </head>
  <body>
    <canvas class="site-noise" data-site-noise aria-hidden="true"></canvas>
    <img class="hero-bg" src={`/assets/hero/${hero}`} alt="" aria-hidden="true" />
    <div class="glow"></div>

    <div class="shell">
      <a class="brand" href="/">
        <img class="brand__logo" src="/assets/card-logo.svg" alt="Glory & Game" />
        <span class="brand__eyebrow">Welcome to</span>
        <span class="brand__name">Glory &amp; Game</span>
      </a>
      <SignIn />
    </div>

    <script type="module" src={siteNoiseScript}></script>
  </body>
</html>
