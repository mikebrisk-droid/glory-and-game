# Clerk authentication
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=glory-and-game-athletes
# Optional but recommended in production to avoid an extra describeIndex call.
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=athletes
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
ADMIN_SECRET=choose-a-strong-admin-secret

# Optional: production EmDash backend. When omitted, production falls back to seeded media content
# and does not expose the EmDash admin runtime.
EMDASH_DATABASE_URL=
EMDASH_DATABASE_AUTH_TOKEN=
EMDASH_STORAGE_ENDPOINT=
EMDASH_STORAGE_BUCKET=
EMDASH_STORAGE_ACCESS_KEY_ID=
EMDASH_STORAGE_SECRET_ACCESS_KEY=
EMDASH_STORAGE_PUBLIC_URL=
EMDASH_STORAGE_REGION=
